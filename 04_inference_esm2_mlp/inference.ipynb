   "source": [
    "import pandas as pd\n",
    "\n",
    "data = pd.read_csv('../data_20230904.csv', index_col = 0)\n",
    "for name in data.index:\n",
    "    with open(f'../mut_data/{name}/result_onlyesm2.txt', 'r') as f:\n",
    "        data.loc[name, 'expression'] = float(f.read())\n",
    "\n",
    "data.corr('spearman')"
   ]
  }
